  font-weight: 500;
  transition: all 0.3s ease;
  box-sizing: border-box;
}
.tab-item.active .tab-icon.data-v-ecc172b4 {
  opacity: 1;
  transform: scale(1.1);
}
.tab-item.active .tab-label.data-v-ecc172b4 {
  color: #4CAF50;
  font-weight: 600;
}
.unread-badge.data-v-ecc172b4 {
  position: absolute;
  top: 25rpx;
  right: 50%;
