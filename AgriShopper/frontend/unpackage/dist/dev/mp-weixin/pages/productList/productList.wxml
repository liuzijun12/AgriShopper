<view class="page-container"><view class="search-bar"><view class="search-input" bindtap="{{b}}"><image src="{{a}}" class="search-icon" mode="aspectFit"></image><text class="search-placeholder">搜索商品名称</text></view></view><view class="content-container"><view class="category-sidebar"><view wx:if="{{c}}" class="category-loading"><text class="loading-text">加载分类中...</text></view><view wx:else class="main-categories"><view wx:for="{{d}}" wx:for-item="category" wx:key="b" class="{{['category-item', category.c, 'cursor-pointer']}}" bindtap="{{category.d}}"><text>{{category.a}}</text></view></view></view><scroll-view class="product-list" scroll-y="true" bindscrolltolower="{{m}}"><view wx:if="{{e}}" class="loading-container"><uni-load-more wx:if="{{f}}" u-i="1df32fa4-0" bind:__l="__l" u-p="{{f}}"></uni-load-more></view><view wx:if="{{g}}" class="error-container"><text class="error-text">{{h}}</text><view class="retry-button" bindtap="{{i}}"><text>重新加载</text></view></view><view wx:for="{{j}}" wx:for-item="product" wx:key="k" class="product-item cursor-pointer" bindtap="{{product.l}}"><image class="product-image" src="{{product.a}}" mode="aspectFill" binderror="{{product.b}}"></image><view class="product-info"><text class="product-name">{{product.c}}</text><text class="product-desc">{{product.d}}</text><view class="product-stats"><view class="stats-row"><text class="stock-info">库存: {{product.e}}</text><view class="product-tags"><text wx:if="{{product.f}}" class="hot-tag">热销</text><text wx:if="{{product.g}}" class="new-tag">新品</text></view></view><view class="stats-row"><text class="unit-info">单位: {{product.h}}</text></view></view><view class="product-bottom"><text class="product-price">¥{{product.i}}</text><view class="buy-button cursor-pointer" catchtap="{{product.j}}"><text>购买</text></view></view></view></view><view wx:if="{{k}}" class="product-count"><text class="count-text">共找到 {{l}} 个商品</text></view></scroll-view></view></view>