<view class="cart-container"><view wx:if="{{a}}" class="empty-cart"><image src="{{b}}" mode="aspectFit" class="empty-cart-image"/><text class="empty-cart-text">购物车是空的</text><button class="go-shopping-btn" bindtap="{{c}}">去逛逛</button></view><scroll-view wx:else scroll-y class="cart-list"><view class="edit-header"><text>共 {{d}} 件商品</text><text class="edit-btn" bindtap="{{f}}">{{e}}</text></view><view class="cart-items"><view wx:for="{{g}}" wx:for-item="item" wx:key="m" class="cart-item"><checkbox-group bindchange="{{item.b}}"><checkbox checked="{{item.a}}" color="#4CAF50"/></checkbox-group><image src="{{item.c}}" mode="aspectFill" class="item-image" bindtap="{{item.d}}"/><view class="item-info"><text class="item-name">{{item.e}}</text><text class="item-spec">{{item.f}}</text><view class="item-price-row"><text class="item-price">¥{{item.g}}</text><view class="quantity-control"><text class="quantity-btn" bindtap="{{item.h}}">-</text><input type="number" class="quantity-input" bindblur="{{item.i}}" value="{{item.j}}" bindinput="{{item.k}}"/><text class="quantity-btn" bindtap="{{item.l}}">+</text></view></view></view></view></view></scroll-view><view class="cart-footer"><view class="select-all"><checkbox-group bindchange="{{i}}"><checkbox checked="{{h}}" color="#4CAF50"/><text>全选</text></checkbox-group></view><view wx:if="{{j}}" class="total-section"><view class="total-price"><text>合计：</text><text class="price">¥{{k}}</text></view><button class="checkout-btn" disabled="{{m}}" bindtap="{{n}}"> 结算({{l}}) </button></view><view wx:else class="delete-section"><button class="delete-btn" disabled="{{p}}" bindtap="{{q}}"> 删除({{o}}) </button></view></view><bottom-tab-bar u-i="7e280b62-0" bind:__l="__l"/></view>