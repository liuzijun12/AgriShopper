<view class="cart-container"><view class="search-header"><view class="search-bar" bindtap="{{b}}"><image class="search-icon" src="{{a}}"></image><text class="search-text">搜索购物车商品</text></view></view><view class="address-bar" bindtap="{{d}}"><image class="address-icon" src="{{c}}"></image><text class="address-text">河北张家口市</text><text class="arrow">›</text></view><view class="promotion-bar"><text class="promotion-tag">满减</text><text class="promotion-text">跨店每满300减30，7月31日24点结束</text></view><view wx:if="{{e}}" class="loading-container"><view class="loading-spinner"></view><text class="loading-text">正在加载购物车...</text></view><view wx:elif="{{f}}" class="empty-cart"><image class="empty-icon" src="{{g}}" mode="aspectFit"></image><text class="empty-text">您的购物车里面空空如也</text><text class="empty-subtext">快去挑选心仪的产品吧</text><button class="go-shopping-btn" bindtap="{{h}}">去购物</button></view><scroll-view wx:else scroll-y class="cart-list"><view class="shop-group"><view class="shop-header"><checkbox-group bindchange="{{j}}"><checkbox checked="{{i}}" color="#e93b3d"/></checkbox-group><text class="shop-name">有机农场直营店</text><text class="coupon-tag">领券</text></view><view wx:for="{{k}}" wx:for-item="item" wx:key="w" class="cart-item-wrapper"><view class="cart-item"><checkbox-group bindchange="{{item.b}}"><checkbox checked="{{item.a}}" color="#e93b3d"/></checkbox-group><view class="item-icon"><image wx:if="{{item.c}}" src="{{item.d}}" mode="aspectFill" class="item-image"/><text wx:else class="icon">{{item.e}}</text></view><view class="item-info"><view class="item-header"><text class="item-name">{{item.f}}</text><text wx:if="{{item.g}}" class="item-tag" style="{{'background-color:' + item.i}}">{{item.h}}</text></view><text class="item-spec">{{item.j}}</text><view class="price-row"><text class="item-price">¥{{item.k}}</text><text wx:if="{{item.l}}" class="original-price">¥{{item.m}}</text></view><view class="item-footer"><text wx:if="{{item.n}}" class="stock">仅剩{{item.o}}件</text><view class="quantity-control"><text class="quantity-btn" bindtap="{{item.p}}">-</text><input type="number" class="quantity-input" bindblur="{{item.q}}" min="1" max="99" value="{{item.r}}" bindinput="{{item.s}}"/><text class="quantity-btn" bindtap="{{item.t}}">+</text></view></view></view></view><view class="delete-btn" bindtap="{{item.v}}"><text class="delete-text">删除</text></view></view></view></scroll-view><view wx:if="{{l}}" class="cart-footer"><view class="select-all"><checkbox-group bindchange="{{n}}"><checkbox checked="{{m}}" color="#e93b3d"/><text>全选</text></checkbox-group></view><view class="price-section"><view class="price-row"><text class="total-text">合计：</text><text class="total-price">¥{{o}}</text></view><view wx:if="{{p}}" class="saved-row"><text class="saved-text">已省</text><text class="saved-price">¥{{q}}</text></view></view><button class="{{['checkout-btn', s && 'disabled']}}" bindtap="{{t}}"> 去结算({{r}}) </button></view></view>