<view class="cart-container"><view class="search-header"><view class="search-bar" bindtap="{{a}}"><text class="search-icon">🔍</text><text class="search-text">搜索购物车商品</text></view></view><view class="address-bar" bindtap="{{b}}"><text class="address-icon">📍</text><text class="address-text">河北张家口市</text><text class="arrow">›</text></view><view class="promotion-bar"><text class="promotion-tag">满减</text><text class="promotion-text">跨店每满300减30，7月31日24点结束</text></view><scroll-view scroll-y class="cart-list"><view class="shop-group"><view class="shop-header"><checkbox-group bindchange="{{d}}"><checkbox checked="{{c}}" color="#e93b3d"/></checkbox-group><text class="shop-name">有机农场直营店</text><text class="coupon-tag">领券</text></view><view wx:for="{{e}}" wx:for-item="item" wx:key="r" class="cart-item"><checkbox-group bindchange="{{item.b}}"><checkbox checked="{{item.a}}" color="#e93b3d"/></checkbox-group><view class="item-icon"><text class="icon">{{item.c}}</text></view><view class="item-info"><view class="item-header"><text class="item-name">{{item.d}}</text><text wx:if="{{item.e}}" class="item-tag" style="{{'background-color:' + item.g}}">{{item.f}}</text></view><text class="item-spec">{{item.h}}</text><view class="price-row"><text class="item-price">¥{{item.i}}</text><text wx:if="{{item.j}}" class="original-price">¥{{item.k}}</text></view><view class="item-footer"><text wx:if="{{item.l}}" class="stock">仅剩{{item.m}}件</text><view class="quantity-control"><text class="quantity-btn" bindtap="{{item.n}}">-</text><input type="number" class="quantity-input" disabled value="{{item.o}}" bindinput="{{item.p}}"/><text class="quantity-btn" bindtap="{{item.q}}">+</text></view></view></view></view></view></scroll-view><view class="cart-footer"><view class="select-all"><checkbox-group bindchange="{{g}}"><checkbox checked="{{f}}" color="#e93b3d"/><text>全选</text></checkbox-group></view><view class="price-section"><text class="total-text">合计：</text><text class="total-price">¥{{h}}</text><text wx:if="{{i}}" class="saved-price">已省¥{{j}}</text></view><button class="{{['checkout-btn', l && 'disabled']}}" bindtap="{{m}}"> 去结算({{k}}) </button></view></view>