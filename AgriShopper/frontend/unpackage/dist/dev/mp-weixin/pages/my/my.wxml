<view class="page"><view class="welcome-section"><text class="welcome-text">欢迎使用农康优选小程序！</text></view><view class="user-info-card"><view class="user-info"><image class="avatar" src="{{a}}" mode="aspectFill"></image><view class="user-details"><text class="username">{{b}}</text></view></view><view class="settings-icon cursor-pointer"><text>设置</text></view></view><view class="order-section"><view wx:for="{{c}}" wx:for-item="item" wx:key="b" class="order-item cursor-pointer"><text class="order-text">{{item.a}}</text></view></view><view class="quick-functions"><view wx:for="{{d}}" wx:for-item="item" wx:key="b" class="function-item cursor-pointer"><text class="function-text">{{item.a}}</text></view></view><view class="address-section"><view class="section-title"><text>地址管理</text></view><view class="address-list"><view wx:for="{{e}}" wx:for-item="address" wx:key="g" class="address-item"><view class="address-info"><view class="address-detail"><text class="address-name">{{address.a}}</text><text class="address-phone">{{address.b}}</text></view><text class="address-text">{{address.c}}</text></view><view class="address-default cursor-pointer" bindtap="{{address.f}}"><view class="{{['radio-button', address.e && 'radio-selected']}}"><view wx:if="{{address.d}}" class="radio-inner"></view></view><text class="default-text">默认地址</text></view></view></view></view></view>